{
  "name": "@repo/domain-visitors",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "development": "./src/index.ts",
        "default": "./dist/index.js"
      },
      "require": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/graphql/schema.d.ts",
      "import": {
        "development": "./src/graphql/schema.graphql",
        "default": "./dist/graphql/schema.js"
      },
      "require": "./dist/graphql/schema.js"
    }
  },
  "scripts": {
    "generate": "graphql-codegen",
    "build": "pnpm run generate && tsc && node ../../scripts/copy-schema.cjs",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@repo/db-core": "workspace:*",
    "@repo/shared-backend": "workspace:^",
    "@repo/shared-common": "workspace:*",
    "graphql": "^16.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/typescript": "^6.0.0",
    "@graphql-codegen/typescript-resolvers": "^6.0.0",
    "@graphql-tools/utils": "^9.0.0",
    "@repo/typescript-config": "workspace:*",
    "typescript": "^6.0.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
