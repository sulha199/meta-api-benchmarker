{
  "name": "@repo/adapter-mongo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "development": "./src/index.ts",
        "default": "./dist/index.js"
      },
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "seed": "tsx src/seed.ts",
    "build": "node ../../scripts/build.mjs && tsc -p tsconfig.build.json",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@repo/shared-common": "workspace:*",
    "@repo/db-core": "workspace:*",
    "@repo/domain-graphql-ast": "workspace:*",
    "@types/node": "^25.7.0",
    "mongoose": "^8.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@repo/typescript-config": "workspace:*",
    "@types/mongoose": "^5.11.97",
    "dotenv": "^17.4.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ]
}
