# Root Environment Variables
# These are inherited by workspace packages

# Neon DB Postgres URL
# Example: postgresql://[user]:[password]@[host]/[db]?sslmode=require
POSTGRES_URL=postgresql://your_postgres_user:your_postgres_password@your_postgres_host/your_database_name?sslmode=require

# MongoDB URI
# Example: mongodb+srv://[user]:[password]@[cluster]/?appName=[appName]
MONGO_URI=mongodb+srv://your_mongo_user:your_mongo_password@your_mongo_cluster.mongodb.net/?appName=yourAppName
