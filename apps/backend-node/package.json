    "@neondatabase/serverless": "^1.1.0",
    "@repo/domain-api-topology": "workspace:*",
    "@repo/domain-graphql-ast": "workspace:*",
    "@repo/domain-visitors": "workspace:*",
    "@repo/schema-drizzle": "workspace:*",
    "@repo/schema-mongo": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.13.2",
    "mongoose": "^8.0.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
