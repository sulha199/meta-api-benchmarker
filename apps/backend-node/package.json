  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "cd ../.. && turbo run build --filter=backend-node",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:sync": "node scripts/sync-supabase.js",
    "db:migrate": "pnpm db:generate && pnpm db:sync",
    "db:seed:postgres": "pnpm --filter @repo/schema-drizzle seed",
    "db:seed:mongo": "pnpm --filter @repo/schema-mongo seed",
    "db:seed": "pnpm db:seed:postgres && pnpm db:seed:mongo",
    "start": "cd ../.. && vercel dev",
    "test": "echo \"Error: no test specified\" && exit 1",
    "serve:local": "pnpm build && node scripts/serve.mjs"
  },
