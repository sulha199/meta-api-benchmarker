{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    /* Set to NodeNext for modern Node.js ESM support */

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,

    "outDir": "./dist",
    "types": ["node"],
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules", "dist"],
}
